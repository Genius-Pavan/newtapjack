<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0d0d0d">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tapjacking Checker"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FF3333"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by Pavan"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Target: Fisher LPG"
        android:textSize="12sp"
        android:textColor="#FF6666"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnCheck"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="CHECK OVERLAY"
        android:textColor="#FFFFFF"
        android:backgroundTint="#CC0000"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnRemove"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="REMOVE OVERLAY"
        android:textColor="#FFFFFF"
        android:backgroundTint="#333333"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Press CHECK OVERLAY to start test.\n\n1. Allow overlay permission\n2. Open Fisher LPG app\n3. Red overlay visible = VULNERABLE"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:padding="16dp"/>

</LinearLayout>
